   "source": [
    "# Digital Twin Demo — Scenario Simulation\n",
    "\n",
    "Demonstrates the digital twin capability: generating patient-specific trajectories\n",
    "and simulating alternative scenarios (\"what if\")."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "sns.set_theme(style='whitegrid', font_scale=1.2)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Build the Hybrid Digital Twin Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.models.hybrid import HybridDigitalTwin\n",
    "\n",
    "static = pd.read_parquet('../outputs/cohort/static_features.parquet')\n",
    "ts = pd.read_parquet('../outputs/cohort/timeseries_processed.parquet')\n",
    "\n",
    "# Use reduced epochs for demo (increase for production)\n",
    "pipeline = HybridDigitalTwin(dgan_epochs=50, dgan_hidden_dim=64, dgan_noise_dim=32)\n",
    "pipeline.fit(static.head(500), ts)\n",
    "print('Model fitted.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Generate a Synthetic Patient"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "result = pipeline.generate(n_patients=1, seed=42)\n",
    "patient_profile = result['static'].iloc[0]\n",
    "trajectory = result['timeseries'][0]  # shape: (seq_len, n_features)\n",
    "\n",
    "print('Patient Profile:')\n",
    "for col in patient_profile.index:\n",
    "    print(f'  {col}: {patient_profile[col]}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot the patient's trajectory\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 8))\n",
    "hours = np.arange(trajectory.shape[0])\n",
    "\n",
    "for ax, feat_idx, title in zip(axes.flat, [0, 1, 4, 5], \n",
    "                                 ['Feature 0', 'Feature 1', 'Feature 4', 'Feature 5']):\n",
    "    if feat_idx < trajectory.shape[1]:\n",
    "        ax.plot(hours, trajectory[:, feat_idx], 'b-', alpha=0.8)\n",
    "        ax.set_xlabel('Hour')\n",
    "        ax.set_title(title)\n",
    "        ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle('Synthetic Patient ICU Trajectory', fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/figures/digital_twin_trajectory.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Scenario-based Simulation\n",
    "\n",
    "What happens if we modify patient characteristics and regenerate trajectories under different scenarios?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.simulation.counterfactual import ScenarioSimulator\n",
    "\n",
    "sim = ScenarioSimulator(pipeline)\n",
    "patient_dict = patient_profile.to_dict()\n",
    "\n",
    "scenarios = {\n",
    "    'Baseline': {},\n",
    "    'Add AFib': {'has_afib': 1},\n",
    "    'Younger (45y)': {'anchor_age': 45},\n",
    "    'Add CKD + Diabetes': {'has_ckd': 1, 'has_diabetes': 1},\n",
    "}\n",
    "\n",
    "results = sim.compare_scenarios(patient_dict, scenarios, n_samples=20)\n",
    "print(f'Generated {len(scenarios)} scenarios, each with 20 trajectory samples.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot scenario comparison\n",
    "fig, axes = plt.subplots(1, len(scenarios), figsize=(5*len(scenarios), 5))\n",
    "colors = sns.color_palette('Set2', len(scenarios))\n",
    "\n",
    "for ax, (name, color) in zip(axes, zip(scenarios.keys(), colors)):\n",
    "    trajs = results[name]['trajectories']\n",
    "    mean_traj = results[name]['mean_trajectory']\n",
    "    std_traj = results[name]['std_trajectory']\n",
    "    \n",
    "    # Plot feature 0 (first vital sign)\n",
    "    feat = 0\n",
    "    if mean_traj.shape[1] > feat:\n",
    "        hours = np.arange(mean_traj.shape[0])\n",
    "        ax.plot(hours, mean_traj[:, feat], color=color, linewidth=2)\n",
    "        ax.fill_between(hours, \n",
    "                        mean_traj[:, feat] - std_traj[:, feat],\n",
    "                        mean_traj[:, feat] + std_traj[:, feat],\n",
    "                        alpha=0.3, color=color)\n",
    "    ax.set_title(name, fontsize=11)\n",
    "    ax.set_xlabel('Hour')\n",
    "    ax.set_ylabel('Feature 0')\n",
    "\n",
    "plt.suptitle('Scenario Comparison (Feature 0, mean +/- SD)', fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/figures/counterfactual_comparison.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
